generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String?   @unique
  emailVerified      DateTime?
  image              String?
  onboardingComplete Boolean   @default(false)
  mascotSkin         String    @default("explorer")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Consent fields (GDPR/RODO compliance)
  termsAcceptedAt    DateTime? // Date of terms acceptance
  privacyAcceptedAt  DateTime? // Date of privacy policy acceptance
  ageConfirmedAt     DateTime? // Confirmation of age >= 16 or parental consent
  parentEmail        String?   // Parent email (optional, if < 16 years)
  consentVersion     String?   // Version of accepted documents (e.g., "1.0")

  // Password authentication fields
  password             String?   // bcrypt hash, null for OAuth-only users
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?

  accounts Account[]
  sessions Session[]
  state    UserState?
  plan     UserPlan?
  usageCounters UsageCounter[]
  subscription  Subscription?
  aiRequestLogs AiRequestLog[]
  aiDailyStats  AiDailyStats[]
}

model UserState {
  id        String   @id @default(cuid())
  userId    String   @unique
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique  // hashed SHA256
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expires])
}

enum Plan {
  FREE
  PRO
}

enum AccessStatus {
  ACTIVE
  WAITLISTED
  SUSPENDED
}

enum WaitlistStatus {
  PENDING
  CONFIRMED
  APPROVED
  DECLINED
}

enum SubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

model UserPlan {
  userId       String       @id
  plan         Plan         @default(FREE)
  accessStatus AccessStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WaitlistEntry {
  id                      String         @id @default(cuid())
  email                   String         @unique
  status                  WaitlistStatus @default(PENDING)
  confirmationTokenHash   String?
  confirmationExpiresAt  DateTime?
  confirmationSentAt     DateTime?
  confirmedAt            DateTime?
  approvedAt             DateTime?
  source                 String?
  language               String?
  metadata               Json?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@index([status, confirmedAt])
}

model UsageCounter {
  id        String   @id @default(cuid())
  userId    String
  period    String
  feature   String
  count     Int      @default(0)
  units     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period, feature])
}

model GlobalUsage {
  id        String   @id @default(cuid())
  period    String
  feature   String
  count     Int      @default(0)
  units     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([period, feature])
}

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  dataType  String   @default("number")
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model ConfigHistory {
  id        String   @id @default(cuid())
  configKey String
  oldValue  String?
  newValue  String
  changedBy String
  changedAt DateTime @default(now())

  @@index([configKey, changedAt])
}

model RateLimitWindow {
  id          String   @id @default(cuid())
  key         String
  windowStart DateTime
  resetAt     DateTime
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, windowStart])
  @@index([key])
  @@index([resetAt])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  status               SubscriptionStatus @default(INCOMPLETE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  trialStart           DateTime?
  trialEnd             DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

// AI Token Analytics - individual request logs
model AiRequestLog {
  id           String   @id @default(cuid())
  userId       String
  sessionId    String?
  feature      String   // generate-words, tutor, pronunciation, etc.
  model        String   // gemini-3-flash-preview, gemini-2.5-pro
  languagePair String?  // pl-en, uk-pl

  inputTokens  Int
  outputTokens Int
  totalTokens  Int

  inputCost    Float    @default(0)
  outputCost   Float    @default(0)
  totalCost    Float    @default(0)

  durationMs   Int
  success      Boolean  @default(true)
  errorType    String?
  errorMessage String?

  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([feature, createdAt])
  @@index([createdAt])
  @@index([sessionId])
}

// AI Token Analytics - daily aggregates per user/feature
model AiDailyStats {
  id           String   @id @default(cuid())
  date         DateTime @db.Date
  userId       String
  feature      String
  model        String
  languagePair String?

  requestCount Int      @default(0)
  successCount Int      @default(0)
  errorCount   Int      @default(0)
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalCost    Float    @default(0)
  avgDurationMs Int     @default(0)
  maxDurationMs Int     @default(0)
  minDurationMs Int     @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([date, userId, feature, model])
  @@index([date])
  @@index([userId, date])
}

// AI Token Analytics - global daily aggregates
model AiGlobalDailyStats {
  id           String   @id @default(cuid())
  date         DateTime @db.Date
  feature      String
  model        String

  requestCount Int      @default(0)
  successCount Int      @default(0)
  errorCount   Int      @default(0)
  uniqueUsers  Int      @default(0)
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalCost    Float    @default(0)
  avgDurationMs Int     @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([date, feature, model])
  @@index([date])
}

// Revenue Strategy Chat - message history
model RevenueChatMessage {
  id              String   @id @default(cuid())
  sessionId       String
  role            String   // 'user' | 'assistant'
  content         String   @db.Text
  contextSnapshot Json?

  createdAt       DateTime @default(now())

  @@index([sessionId, createdAt])
}
