# ============================================================
# Henio – local development environment
# Copy this file to `.env` and fill in values marked [REQUIRED].
# Everything else is optional and can stay blank for a first run.
# ============================================================

# --- [REQUIRED] Core app ---------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-change-me-to-any-random-string
APP_ENV=development

# --- [REQUIRED] Database ---------------------------------------------------
# Matches docker-compose.yml (postgres:16 on localhost:5432)
DATABASE_URL=postgresql://vocab:vocab@localhost:5432/vocab

# --- [OPTIONAL] Google OAuth -----------------------------------------------
# Leave blank to use only the email+password demo login seeded by `npm run db:seed`.
# To enable "Sign in with Google", create credentials at
# https://console.cloud.google.com/apis/credentials and set the redirect URI to
# http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- [OPTIONAL] Gemini AI --------------------------------------------------
# Without this key, AI features (word generation, tutor, pronunciation summary)
# return HTTP 503 – the rest of the app still works.
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- [OPTIONAL] Stripe (PRO plan subscriptions) ----------------------------
# Without these, checkout/portal/webhook endpoints are disabled.
# Use Stripe test keys for local dev: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=

# --- [OPTIONAL] Email (transactional SMTP) ---------------------------------
# Needed only for self-service registration + password reset.
# The seeded demo user already has a verified email, so you can skip this.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_REPLY_TO=

# --- [OPTIONAL] Access control ---------------------------------------------
# Leave blank to allow everyone. Set your email in ADMIN_EMAILS to unlock
# the admin panel at /admin.
ALLOWLIST_EMAILS=
ADMIN_EMAILS=
MAX_ACTIVE_USERS=100

# --- [OPTIONAL] AI usage limits (monthly) ----------------------------------
FREE_AI_REQUESTS_PER_MONTH=60
FREE_AI_UNITS_PER_MONTH=120000
PRO_AI_REQUESTS_PER_MONTH=600
PRO_AI_UNITS_PER_MONTH=1200000
GLOBAL_AI_REQUESTS_PER_MONTH=6000
GLOBAL_AI_UNITS_PER_MONTH=12000000
AI_COST_HARD_LIMIT_USD=0

# --- [OPTIONAL] Waitlist / cron --------------------------------------------
WAITLIST_CONFIRM_TTL_HOURS=24
WAITLIST_CONFIRM_RESEND_MINUTES=10
WAITLIST_CRON_SECRET=

# --- [OPTIONAL] Seed override ----------------------------------------------
# Overrides the demo user created by `npm run db:seed`.
# Defaults: demo@henio.local / demo1234
SEED_EMAIL=
SEED_PASSWORD=
SEED_NAME=
